---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: '⚡',
    title: 'Blazing Fast',
    description: 'Optimized for performance out of the box. Pages load in milliseconds, not seconds — giving users the snappy experience they expect.',
  },
  {
    icon: '🎨',
    title: 'Beautiful by Default',
    description: 'Thoughtfully crafted components and layouts that look great from day one. No design degree required.',
  },
  {
    icon: '🔒',
    title: 'Secure & Reliable',
    description: 'Enterprise-grade security baked in. Role-based access, encrypted storage, and audit logs keep your data safe.',
  },
  {
    icon: '🔌',
    title: 'Extensible',
    description: 'A rich plugin ecosystem and open APIs let you connect Ethereal to any tool in your workflow.',
  },
  {
    icon: '📊',
    title: 'Powerful Analytics',
    description: 'Real-time dashboards and reports give you the insight to make confident, data-driven decisions.',
  },
  {
    icon: '🤝',
    title: 'Built for Teams',
    description: 'Collaborative workflows, shared workspaces, and live cursors make working together feel effortless.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Create Your Workspace',
    description: 'Sign up in seconds and set up your team workspace. Invite collaborators with a single click.',
  },
  {
    number: '02',
    title: 'Connect Your Tools',
    description: 'Integrate with your favourite services — Slack, GitHub, Figma, and 50+ more — in minutes.',
  },
  {
    number: '03',
    title: 'Ship Faster',
    description: 'Use our AI-powered workflows to automate repetitive tasks and focus on what matters most.',
  },
];

const testimonials = [
  {
    quote: "Ethereal completely transformed how our team ships product. We cut release cycles from two weeks to two days. I can't imagine going back.",
    name: 'Sarah Chen',
    role: 'VP of Engineering at Nimbus',
    avatar: 'SC',
    color: '#6d28d9',
  },
  {
    quote: "The onboarding experience was genuinely delightful. We were productive from day one — no lengthy setup, no confusing docs.",
    name: 'Marcus Rivera',
    role: 'Co-founder & CTO at Stackly',
    avatar: 'MR',
    color: '#0891b2',
  },
  {
    quote: "Our design and engineering teams finally speak the same language. Ethereal's shared workspace is the missing piece we didn't know we needed.",
    name: 'Aisha Patel',
    role: 'Head of Design at Forma',
    avatar: 'AP',
    color: '#059669',
  },
];

const stats = [
  { value: '50K+', label: 'Teams worldwide' },
  { value: '99.9%', label: 'Uptime SLA' },
  { value: '3.2s', label: 'Avg. time saved per task' },
  { value: '4.9★', label: 'Average rating' },
];
---

<Layout title="Ethereal — Build Something Beautiful">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg-glow"></div>
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Now in public beta — free for teams under 5
      </div>
      <h1 class="hero-title">
        Build something<br />
        <span class="hero-gradient">truly ethereal.</span>
      </h1>
      <p class="hero-subtitle">
        The all-in-one platform for modern teams to design, collaborate, and ship
        beautiful digital experiences — faster than ever before.
      </p>
      <div class="hero-actions">
        <a href="#" class="btn btn-primary btn-lg">
          Start for free
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#how-it-works" class="btn btn-outline btn-lg">See how it works</a>
      </div>
      <div class="hero-social-proof">
        <div class="avatar-stack">
          {['#6d28d9','#0891b2','#059669','#d97706','#dc2626'].map((c) => (
            <span class="avatar" style={`background:${c}`}></span>
          ))}
        </div>
        <p class="social-proof-text">
          Trusted by <strong>50,000+</strong> teams around the world
        </p>
      </div>
    </div>
    <div class="hero-visual">
      <div class="container">
        <div class="dashboard-mockup">
          <div class="mockup-bar">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="mockup-url">app.ethereal.io/dashboard</span>
          </div>
          <div class="mockup-body">
            <div class="mockup-sidebar">
              {['Dashboard','Projects','Team','Analytics','Settings'].map((item) => (
                <div class="sidebar-item">{item}</div>
              ))}
            </div>
            <div class="mockup-content">
              <div class="mockup-card accent"></div>
              <div class="mockup-row">
                <div class="mockup-card small"></div>
                <div class="mockup-card small"></div>
                <div class="mockup-card small"></div>
              </div>
              <div class="mockup-card wide"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        {stats.map((stat) => (
          <div class="stat-item">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section features-section" id="features">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">Features</span>
        <h2 class="section-title">Everything your team needs</h2>
        <p class="section-subtitle">
          From ideation to deployment, Ethereal gives every member of your team
          the tools they need to do their best work.
        </p>
      </div>
      <div class="features-grid">
        {features.map((feature) => (
          <div class="feature-card">
            <div class="feature-icon">{feature.icon}</div>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-description">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section how-section" id="how-it-works">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">How It Works</span>
        <h2 class="section-title">Up and running in minutes</h2>
        <p class="section-subtitle">
          No lengthy setup. No complicated onboarding. Just three simple steps
          to transform how your team works.
        </p>
      </div>
      <div class="steps-grid">
        {steps.map((step, i) => (
          <div class="step-card">
            <span class="step-number">{step.number}</span>
            {i < steps.length - 1 && <span class="step-connector"></span>}
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials-section" id="testimonials">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">Testimonials</span>
        <h2 class="section-title">Loved by builders everywhere</h2>
        <p class="section-subtitle">
          Don't just take our word for it — here's what teams using Ethereal
          have to say.
        </p>
      </div>
      <div class="testimonials-grid">
        {testimonials.map((t) => (
          <div class="testimonial-card">
            <div class="quote-mark">"</div>
            <p class="testimonial-quote">{t.quote}</p>
            <div class="testimonial-author">
              <span class="author-avatar" style={`background:${t.color}`}>
                {t.avatar}
              </span>
              <div class="author-info">
                <span class="author-name">{t.name}</span>
                <span class="author-role">{t.role}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-glow"></div>
        <span class="section-label">Get Started Today</span>
        <h2 class="cta-title">Ready to build something ethereal?</h2>
        <p class="cta-subtitle">
          Join 50,000+ teams already using Ethereal. Free to start, no credit card required.
        </p>
        <div class="cta-actions">
          <a href="#" class="btn btn-primary btn-lg">
            Start for free
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/aboutus" class="btn btn-outline btn-lg" style="border-color: rgba(255,255,255,0.3); color: #fff;">
            Learn about us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(170deg, #faf9ff 0%, #f0ecff 50%, #faf9ff 100%);
  }

  .hero-bg-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(109,40,217,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    padding-top: 96px;
    padding-bottom: 72px;
    text-align: center;
    max-width: 760px;
    margin-inline: auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary);
    background: rgba(109,40,217,0.08);
    border: 1px solid rgba(109,40,217,0.2);
    padding: 6px 16px;
    border-radius: var(--radius-full);
    margin-bottom: 28px;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .hero-gradient {
    background: linear-gradient(135deg, var(--color-primary) 0%, #a78bfa 50%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-text-muted);
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .hero-social-proof {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
  }

  .avatar-stack {
    display: flex;
    margin-right: 4px;
  }

  .avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: block;
    margin-right: -8px;
    opacity: 0.85;
  }

  .social-proof-text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .social-proof-text strong {
    color: var(--color-text);
  }

  /* Dashboard mockup */
  .hero-visual {
    padding-bottom: 72px;
  }

  .dashboard-mockup {
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(109,40,217,0.08);
    overflow: hidden;
    max-width: 860px;
    margin-inline: auto;
  }

  .mockup-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: #f9fafb;
    border-bottom: 1px solid var(--color-border);
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }

  .dot.red { background: #f87171; }
  .dot.yellow { background: #fbbf24; }
  .dot.green { background: #34d399; }

  .mockup-url {
    margin-left: 8px;
    font-size: 0.75rem;
    color: #9ca3af;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 3px 10px;
  }

  .mockup-body {
    display: grid;
    grid-template-columns: 160px 1fr;
    min-height: 280px;
  }

  .mockup-sidebar {
    background: #fafafa;
    border-right: 1px solid var(--color-border);
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-item {
    font-size: 0.8rem;
    color: #9ca3af;
    padding: 7px 10px;
    border-radius: 6px;
    cursor: pointer;
  }

  .sidebar-item:first-child {
    background: var(--color-bg-muted);
    color: var(--color-primary);
    font-weight: 600;
  }

  .mockup-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .mockup-card {
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-bg-muted) 0%, var(--color-border-subtle) 100%);
  }

  .mockup-card.accent {
    height: 80px;
    background: linear-gradient(135deg, rgba(109,40,217,0.15) 0%, rgba(167,139,250,0.1) 100%);
    border: 1px solid rgba(109,40,217,0.1);
  }

  .mockup-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .mockup-card.small { height: 54px; }
  .mockup-card.wide { height: 64px; }

  /* ── Stats ── */
  .stats-section {
    background: var(--color-text);
    padding-block: 56px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 20px;
    border-right: 1px solid rgba(255,255,255,0.08);
  }

  .stat-item:last-child {
    border-right: none;
  }

  .stat-value {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #9ca3af;
  }

  /* ── Features ── */
  .features-section {
    background: var(--color-bg);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .feature-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 32px 28px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    border-color: rgba(109,40,217,0.3);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 16px;
    line-height: 1;
  }

  .feature-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .feature-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  /* ── How It Works ── */
  .how-section {
    background: var(--color-bg-subtle);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .step-card {
    position: relative;
    text-align: center;
    padding: 40px 24px;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 20px;
    box-shadow: 0 6px 20px rgba(109,40,217,0.3);
  }

  .step-connector {
    position: absolute;
    top: 68px;
    right: -24px;
    width: 48px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary), transparent);
    opacity: 0.3;
  }

  .step-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  .step-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  /* ── Testimonials ── */
  .testimonials-section {
    background: var(--color-bg);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testimonial-card {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 32px 28px;
    position: relative;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .testimonial-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .quote-mark {
    font-size: 5rem;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.15;
    font-family: Georgia, serif;
    position: absolute;
    top: 12px;
    left: 24px;
    pointer-events: none;
  }

  .testimonial-quote {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .author-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .author-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .author-role {
    font-size: 0.8rem;
    color: var(--color-text-subtle);
  }

  /* ── CTA ── */
  .cta-section {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 50%, #7c3aed 100%);
    padding-block: 96px;
  }

  .cta-inner {
    position: relative;
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(255,255,255,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner .section-label {
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .cta-subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.75);
    margin-bottom: 40px;
    line-height: 1.65;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .cta-actions .btn-primary {
    background: #fff;
    color: var(--color-primary);
  }

  .cta-actions .btn-primary:hover {
    background: #f3f4f6;
    box-shadow: 0 6px 24px rgba(0,0,0,0.15);
  }

  .cta-actions .btn-outline:hover {
    background: rgba(255,255,255,0.1);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .features-grid,
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .steps-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .step-connector {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat-item:nth-child(2) {
      border-right: none;
    }

    .features-grid,
    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .mockup-body {
      grid-template-columns: 1fr;
    }

    .mockup-sidebar {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
